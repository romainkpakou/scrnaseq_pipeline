// =============================================================================
// CONFIGURATION NEXTFLOW : scrnaseq_pipeline
// =============================================================================

// Manifeste : metadonnees du pipeline, affichees par `nextflow info` et
// exploitees lors d'un lancement depuis un depot distant.
manifest {
    name            = 'scrnaseq_pipeline'
    author          = 'Romain KPAKOU'
    homePage        = 'https://github.com/romainkpakou/scrnaseq_pipeline'
    description     = 'Pipeline Nextflow DSL2 pour l\'analyse single-cell RNA-seq'
    version         = '0.2.1'
    nextflowVersion = '>=22.04.0'
    mainScript      = 'main.nf'
}

// Parametres par defaut, surchargeables en ligne de commande.
params {
    config      = "${projectDir}/params/example_pbmc.yaml"
    input_path  = null
    output_path = "results"
}

// Profils d'execution. Le profil s'active par -profile <nom>, et plusieurs
// profils se combinent par virgule (par exemple -profile slurm,conda).
profiles {

    // Execution locale avec l'environnement R du systeme. Profil par defaut.
    standard {
        process.executor = 'local'
    }

    // Environnement Conda isole, garantissant les versions de dependances.
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment/environment.yml"
    }

    // Soumission sur ordonnanceur SLURM pour execution sur cluster de calcul.
    // Les ressources sont volontairement generiques : elles doivent etre
    // ajustees a l'infrastructure cible et a la taille du jeu de donnees.
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        process.memory   = '16 GB'
        process.cpus     = 4
        process.time     = '4h'
    }
}

// Rapports d'execution generes automatiquement. Ils documentent la
// consommation de ressources et la duree de chaque tache, ce qui facilite le
// dimensionnement lors d'un passage sur cluster.
// overwrite = true evite un echec au relancement dans un repertoire existant.
trace {
    enabled   = true
    overwrite = true
    file      = "${params.output_path}/pipeline_info/trace.txt"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.output_path}/pipeline_info/execution_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.output_path}/pipeline_info/timeline.html"
}
